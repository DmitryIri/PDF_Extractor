# === Python ===
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
.env

# === Runtime artifacts (FORBIDDEN in repo) ===
tmp/
runs/
artifacts/
downloads/
output/
results/
logs/
# === PDF & data artifacts ===
*.pdf
*.dump
*.json
*.log
# === OS / IDE ===
.DS_Store
.idea/
.vscode/
# === Claude Code skill backup artifacts ===
.claude/skills/**/*.bak_*
# === Claude Code temporary files ===
conversation-*.txt
*-you-are-in-doc-editing-mode-*.txt
/*-claude-code-task-*.txt
# === Secrets ===
.env.*
# Allow tracking of normative JSON schemas and contracts
!docs/
!docs/**/*.json
# Allow test fixture JSON
!tests/fixtures/
!tests/fixtures/*.json
# Allow golden test artifacts
!golden_tests/
!golden_tests/**/*.json
# Allow project-level Claude Code settings
!.claude/settings.json
_audit/
# Allow committing claude audit reports even if _audit is generally ignored
!_audit/
_audit/*
!_audit/claude_code/
_audit/claude_code/*
!_audit/claude_code/reports/
_audit/claude_code/reports/*
!_audit/claude_code/reports/*/
# Ignore nested _audit anomaly (malformed structure from previous ops)
_audit/claude_code/reports/_audit/
