# === Python ===
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
.env

# === Runtime artifacts (FORBIDDEN in repo) ===
tmp/
runs/
artifacts/
downloads/
output/
results/
logs/
# === PDF & data artifacts ===
*.pdf
*.dump
*.json
*.log
# === OS / IDE ===
.DS_Store
.idea/
.vscode/
# === Claude Code temporary files ===
conversation-*.txt
*-you-are-in-doc-editing-mode-*.txt
# === Secrets ===
.env.*
# Allow tracking of normative JSON schemas and contracts
!docs/
!docs/**/*.json
# Allow golden test artifacts
!golden_tests/
!golden_tests/**/*.json
# Allow project-level Claude Code settings
!.claude/settings.json
_audit/
